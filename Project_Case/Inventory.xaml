<Window x:Class="CS2_CaseOpening.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory" Height="650" Width="1000" Background="#121212">

    <Window.Resources>
        <Style x:Key="InventoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1c1c1c"/>
            <Setter Property="BorderBrush" Value="#2d2d2d"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border Height="4" Background="#3d3d3d" VerticalAlignment="Bottom" Margin="2"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="Gold"/>
                    <Setter Property="Background" Value="#252525"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot1" Click="Slot_Click">
            <Image Source="fotka1.png"/>
        </Button>
        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot2" Click="Slot_Click">
            <Image Source="fotka2.png"/>
        </Button>
        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot3" Click="Slot_Click"/>
        <Button Grid.Row="0" Grid.Column="3" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot4" Click="Slot_Click"/>
        <Button Grid.Row="0" Grid.Column="4" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot5" Click="Slot_Click"/>
        <Button Grid.Row="0" Grid.Column="5" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot6" Click="Slot_Click"/>

        <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot7" Click="Slot_Click"/>
        <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot8" Click="Slot_Click"/>
        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot9" Click="Slot_Click"/>
        <Button Grid.Row="1" Grid.Column="3" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot10" Click="Slot_Click"/>
        <Button Grid.Row="1" Grid.Column="4" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot11" Click="Slot_Click"/>
        <Button Grid.Row="1" Grid.Column="5" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot12" Click="Slot_Click"/>

        <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot13" Click="Slot_Click"/>
        <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot14" Click="Slot_Click"/>
        <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot15" Click="Slot_Click"/>
        <Button Grid.Row="2" Grid.Column="3" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot16" Click="Slot_Click"/>
        <Button Grid.Row="2" Grid.Column="4" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot17" Click="Slot_Click"/>
        <Button Grid.Row="2" Grid.Column="5" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot18" Click="Slot_Click"/>

        <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot19" Click="Slot_Click"/>
        <Button Grid.Row="3" Grid.Column="1" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot20" Click="Slot_Click"/>
        <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot21" Click="Slot_Click"/>
        <Button Grid.Row="3" Grid.Column="3" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot22" Click="Slot_Click"/>
        <Button Grid.Row="3" Grid.Column="4" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot23" Click="Slot_Click"/>
        <Button Grid.Row="3" Grid.Column="5" Style="{StaticResource InventoryButtonStyle}" x:Name="Slot24" Click="Slot_Click"/>
    </Grid>
</Window>