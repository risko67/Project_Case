<Window x:Class="CS2_CaseOpening.Inventory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory" Height="650" Width="1000" 
        Background="#121212" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="InventoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1c1c1c"/>
            <Setter Property="BorderBrush" Value="#2d2d2d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10"/>
                                <Border Height="5" VerticalAlignment="Bottom" Margin="2,0,2,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#4b69ff"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}" Value="Red">
                                                    <Setter Property="Background" Value="#eb4b4b"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}" Value="Gold">
                                                    <Setter Property="Background" Value="#caab05"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="15">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
            <Button Content="← SPÄŤ DO MENU" Click="btnBack_Click" HorizontalAlignment="Left" 
                    Background="Transparent" Foreground="Gray" BorderThickness="0" Cursor="Hand"/>
            <TextBlock x:Name="txtTitle" Text="INVENTÁR" Foreground="White" FontSize="24" 
                       FontWeight="Bold" HorizontalAlignment="Center"/>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <UniformGrid x:Name="InventoryGrid" Columns="6">
                <Button Style="{StaticResource InventoryButtonStyle}" Tag="Case" >
                    <Image Source="C:\Users\Michal Ciprich\source\repos\Project_Case\Project_Case\Chroma Case\Chroma Case.webp" Height="100" Width="100"/>
                </Button>
            </UniformGrid>
        </ScrollViewer>
    </DockPanel>
</Window>