<Window x:Class="CS2_CaseOpening.Inventory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory"
        Height="650"
        Width="1000"
        Background="#121212"
        WindowStartupLocation="CenterScreen">

    <DockPanel Margin="15">

      
        <Grid DockPanel.Dock="Top" Margin="0,0,0,15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

           
            <Button Content="← SPÄŤ DO MENU"
                    Click="btnBack_Click"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Foreground="Gray"
                    BorderThickness="0"
                    Cursor="Hand"/>

           
            <TextBlock x:Name="txtTitle"
                       Text="INVENTÁR"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Grid.Column="1"/>

           
            <TextBlock x:Name="txtBalance"
                       Text="Balance: 0€"
                       Foreground="Gold"
                       FontSize="18"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Grid.Column="2"
                       Margin="0,0,10,0"/>
        </Grid>

        <!-- INVENTORY -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel>
               
                <UniformGrid x:Name="RegularGrid"
                             Columns="6"/>

                
                <TextBlock x:Name="txtSpecialLabel"
                           Text="SPECIAL CASES"
                           Foreground="#FFD700"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,12,0,6"
                           Visibility="Collapsed"/>

                
                <UniformGrid x:Name="SpecialGrid"
                             Columns="6"
                             Visibility="Collapsed"/>
            </StackPanel>

        </ScrollViewer>

    </DockPanel>
</Window>