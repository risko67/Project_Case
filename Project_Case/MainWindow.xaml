<Window x:Class="CS2_CaseOpening.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CS2 Case Simulator - Login" Height="450" Width="400"
        Background="#121212" WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="CS2 CASE OPENER" Foreground="#FFD700" 
                       FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Username" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox x:Name="txtUsername" Height="35" Background="#1e1e1e" Foreground="White" 
                     BorderBrush="#333" Padding="5" VerticalContentAlignment="Center"/>

            <TextBlock Text="Password" Foreground="Gray" Margin="0,15,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="35" Background="#1e1e1e" Foreground="White" 
                         BorderBrush="#333" Padding="5" VerticalContentAlignment="Center"/>

            <Button x:Name="btnLogin" Content="LOGIN" Margin="0,30,0,0" Height="40" 
                    Background="#FFD700" FontWeight="Bold" Cursor="Hand"
                    Click="btnLogin_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock x:Name="lblError" Foreground="Red" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            <Button x:Name="btnRegister_Copy" Content="REGISTER" Height="40" 
                Background="#FFD700" FontWeight="Bold" Cursor="Hand"
                Click="btnLogin_Click">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
