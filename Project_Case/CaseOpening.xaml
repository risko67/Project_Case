        <Window x:Class="CS2_CaseOpening.CaseOpening"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Opening Case..." Height="400" Width="800" 
        Background="#121212" WindowStartupLocation="CenterScreen">

    <Grid VerticalAlignment="Center">
        <StackPanel>
            <Border BorderBrush="#FFD700" BorderThickness="2" Height="150" Margin="0,20" 
                    Background="#1a1a1a" HorizontalAlignment="Stretch" ClipToBounds="True">
                <Grid>
                    <Canvas x:Name="SkinsCanvas" Height="150" VerticalAlignment="Center"/>

                    <Rectangle Width="3" Fill="Red" Height="150" HorizontalAlignment="Center" Panel.ZIndex="10"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                <Button x:Name="btnSpin" Content="OPEN CASE (2.50€)" Width="200" Height="50" 
                        Background="#FFD700" FontWeight="Bold" FontSize="16" Click="btnSpin_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnBackToInventory" Content="BACK" Width="100" Height="50"
                        Margin="12,0,0,0"
                        Background="Transparent" Foreground="White" BorderBrush="#333"
                        FontWeight="Bold" Cursor="Hand"
                        Click="btnBackToInventory_Click"/>
            </StackPanel>

            <TextBlock x:Name="txtStatus" Foreground="White" HorizontalAlignment="Center" Margin="0,10" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>