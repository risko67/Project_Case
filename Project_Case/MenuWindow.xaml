<Window x:Class="CS2_CaseOpening.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CS2 Case Simulator - Menu" Height="450" Width="700" 
        Background="#121212" WindowStartupLocation="CenterScreen">

    <Grid Margin="40">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="HLAVNÉ MENU" Foreground="#FFD700" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <UniformGrid Columns="2" Height="150">
                <Button x:Name="btnGoToCases" Margin="10" Background="#1e1e1e" BorderBrush="#FFD700" Cursor="Hand" Click="btnGoToCases_Click">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="40" Foreground="White"    HorizontalAlignment="Center"/>
                        <TextBlock Text="OTVÁRAŤ BEDNE" Foreground="White" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnGoToSkins" Margin="10" Background="#1e1e1e" BorderBrush="#4b69ff" Cursor="Hand" Click="btnGoToSkins_Click">
                    <StackPanel>
                        <TextBlock Text="🔫" FontSize="40" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="MOJE SKINY" Foreground="White" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <Button Content="ODHLÁSIŤ SA" Width="150" Height="35" Margin="0,40,0,0" Background="#333" Foreground="White" Click="btnLogout_Click"/>
        </StackPanel>
    </Grid>
</Window>